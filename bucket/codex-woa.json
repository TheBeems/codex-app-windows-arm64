{
  "version": "26.527.3686.2",
  "description": "Unofficial Windows ARM64 repackaging of the OpenAI Codex app.",
  "homepage": "https://github.com/airtaxi/codex-app-windows-arm64",
  "license": "MIT",
  "architecture": {
    "arm64": {
      "url": "https://github.com/airtaxi/codex-app-windows-arm64/releases/download/26.527.3686.2/dist.7z",
      "hash": "a17a0398a8428d34a1d4633bd2f3e584c7753efd48dd365afb9306c03dd37d2e"
    }
  },
  "installer": {
    "script": [
      "$msix = Get-ChildItem -LiteralPath $dir -Filter \"Codex-WoA_*_arm64.msix\" | Select-Object -First 1",
      "$cer = Join-Path $dir \"CodexWoA.cer\"",
      "if (-not $msix) { throw \"Codex WoA MSIX not found.\" }",
      "if (-not (Test-Path -LiteralPath $cer)) { $cer = Join-Path $dir \"cert\\CodexWoA.cer\" }",
      "& (Join-Path $dir \"Install.ps1\") -MsixPath $msix.FullName -CerPath $cer",
      "if ($LASTEXITCODE) { exit $LASTEXITCODE }"
    ]
  },
  "notes": "Install.ps1 imports the included local signing certificate into TrustedPeople and may request elevation."
}
